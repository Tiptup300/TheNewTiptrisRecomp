# =========================================================================
#  Never commit the ROM or any GAME DATA extracted from it (graphics, audio,
#  level data). Those are loaded from the user's own ROM at runtime and stored
#  locally — they are NEVER checked in.
#  The recompiled program *code* (RecompiledFuncs / rsp microcode) IS committed
#  and shipped in the binary, as is standard for N64Recomp ports (Banjo/Zelda).
#  It is a machine translation of code, not game assets. The end user still must
#  supply their own ROM at runtime for the game data.
# =========================================================================

# --- ROMs / game images (never commit) ---
*.z64
*.n64
*.v64
*.rom
*.elf
baserom*

# --- Rendered game frames / screenshots (contain copyrighted game imagery) ---
/shots/

# --- External dependencies (cloned per README; see build instructions) ---
/lib/

# --- Mesa Dozen driver (extracted binary, not ours to redistribute) ---
/dzn/

# --- Build output ---
/build-cmake/
/build/
/out/
/dist/
*.o
*.exe
*.dll
*.lib
*.pdb

# --- Recompiler binaries ---
/N64Recomp
/RSPRecomp

# --- Logs / scratch ---
*.log
*.raw
*.tmp
rt64.log
imgui.ini

# --- Local config / saves (config dir may hold a stored copy of the ROM) ---
/config/
