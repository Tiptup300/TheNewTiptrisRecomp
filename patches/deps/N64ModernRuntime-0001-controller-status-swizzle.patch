+// Write a single byte into rdram at the (unswizzled) location `host_ptr` points
+// to, applying the recompiled game's byte swizzle (bytes live at index ^ 3).
+// This makes HLE struct writes correct regardless of the struct's alignment,
+// unlike the "reversed field order" trick which only works when 4-byte aligned.
+static inline void sw_write8(uint8_t* rdram, void* host_ptr, uint8_t val) {
+    size_t idx = (uint8_t*)host_ptr - rdram;
+    rdram[idx ^ 3] = val;
+}
+
+// `data` points at the game's OSContStatus array (big-endian layout:
+// type@0(u16), status@2(u8), err_no@3(u8)). `pattern` points at the game's
+// bitpattern byte (may be null to skip, e.g. osContGetQuery).
+static void __osContGetInitData(RDRAM_ARG u8* pattern, OSContStatus *data) {
+    uint8_t* base = (uint8_t*)data;
+    uint8_t pat = 0;
 
