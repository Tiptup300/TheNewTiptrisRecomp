-            data[controller].status = device_info.connected_pak != ultramodern::input::Pak::None;
-            data[controller].err_no = 0x00;
+            sw_write8(rdram, slot + 0, (uint8_t)(type >> 8)); // type high (big-endian)
+            sw_write8(rdram, slot + 1, (uint8_t)(type & 0xFF)); // type low
